{
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "ackMaxChars": 300,
        "activeHours": {
          "end": "22:30",
          "start": "09:30",
          "timezone": "America/New_York"
        },
        "every": "120m",
        "isolatedSession": true,
        "lightContext": true,
        "model": "openrouter/openai/gpt-5-mini",
        "suppressToolErrorWarnings": true,
        "target": "last"
      },
      "llm": {
        "idleTimeoutSeconds": 300
      },
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4.6"
      },
      "sandbox": {
        "mode": "off"
      },
      "thinkingDefault": "low",
      "timeoutSeconds": 180,
      "workspace": "/home/node/.openclaw/workspace"
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "mode": "api_key",
        "provider": "openrouter"
      }
    }
  },
  "browser": {
    "defaultProfile": "openclaw",
    "enabled": true,
    "noSandbox": true
  },
  "channels": {
    "telegram": {
      "allowFrom": [
        "7540422842",
        "8790259622"
      ],
      "direct": {
        "8790259622": {
          "enabled": true,
          "systemPrompt": "You are talking with Cayce \u2014 Kenny's wife. She has open access: feel free to share anything you would tell Kenny, including schedule, calendar, plans, current focus, family details, and life context. Use the same warm, candid, direct tone you use with Kenny \u2014 full personality, dry humor allowed \u2014 but with NO flirty, romantic, or affectionate banter; that register is exclusively for Kenny. You may read shared context files and Google Calendar via gog. You MUST NOT create, edit, or delete Google Calendar events on Kenny's calendars. If she says 'remember this' or 'put it on Kenny's calendar', acknowledge politely but explain you only do those for Kenny \u2014 offer to relay it to him instead.",
          "tools": {
            "deny": [
              "write",
              "edit",
              "apply_patch"
            ]
          }
        }
      },
      "dmPolicy": "allowlist",
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "tokenFile": "<set manually>"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "<set manually>"
    },
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18791"
      ]
    },
    "mode": "local",
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    },
    "port": 18791,
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "hooks": {
    "internal": {
      "entries": {
        "session-memory": {
          "enabled": false
        }
      }
    }
  },
  "mcp": {
    "servers": {
      "todoist": {
        "headers": {
          "Authorization": "<set manually>"
        },
        "transport": "streamable-http",
        "url": "https://ai.todoist.net/mcp"
      }
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "command": "/home/node/.openclaw/bin/qmd",
      "includeDefaultMemory": true,
      "limits": {
        "maxResults": 6,
        "timeoutMs": 4000
      },
      "paths": [
        {
          "name": "mira-root-docs",
          "path": "/home/node/.openclaw/workspace",
          "pattern": "*.md"
        },
        {
          "name": "mira-skills",
          "path": "/home/node/.openclaw/workspace/skills",
          "pattern": "**/*.md"
        },
        {
          "name": "mira-capabilities",
          "path": "/home/node/.openclaw/workspace/capabilities",
          "pattern": "**/*.md"
        },
        {
          "name": "dripr-repo-skills",
          "path": "/home/node/.openclaw/workspace/runtime/repos/dripr/.agent/skills",
          "pattern": "**/SKILL.md"
        }
      ],
      "scope": {
        "default": "deny",
        "rules": [
          {
            "action": "allow",
            "match": {
              "chatType": "direct"
            }
          }
        ]
      },
      "searchMode": "search",
      "sessions": {
        "enabled": false
      }
    }
  },
