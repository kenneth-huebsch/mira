{
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "llm": {
        "idleTimeoutSeconds": 300
      },
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4.6"
      },
      "sandbox": {
        "mode": "off"
      },
      "thinkingDefault": "low",
      "timeoutSeconds": 600,
      "workspace": "/home/node/.openclaw/workspace"
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "mode": "api_key",
        "provider": "openrouter"
      }
    }
  },
  "channels": {
    "telegram": {
      "allowFrom": [
        "7540422842"
      ],
      "dmPolicy": "allowlist",
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "tokenFile": "<set manually>"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "<set manually>"
    },
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18791"
      ]
    },
    "mode": "local",
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    },
    "port": 18791,
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "hooks": {
    "internal": {
      "entries": {
        "session-memory": {
          "enabled": false
        }
      }
    }
  },
  "plugins": {
    "entries": {
      "anthropic": {
        "enabled": true
      },
      "openrouter": {
        "enabled": true
      }
    },
    "installs": {},
    "load": {
      "paths": []
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "skills": {
    "entries": {
      "coding-harness": {
        "enabled": true
      },
      "cursor-agent-login": {
        "enabled": true
      },
      "gog": {
        "enabled": true
      },
      "gog-reauth": {
        "enabled": true
      },
      "model-usage": {
        "enabled": false
      },
      "session-logs": {
        "enabled": false
      }
    }
  },
  "tools": {
    "exec": {
      "host": "gateway"
    },
    "profile": "coding",
    "sessions": {
      "visibility": "agent"
    }
  }
}
