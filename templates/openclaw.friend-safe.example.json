{
  "agents": {
    "defaults": {
      "compaction": {
        "mode": "safeguard"
      },
      "llm": {
        "idleTimeoutSeconds": 300
      },
      "model": {
        "primary": "openrouter/anthropic/claude-sonnet-4.6"
      },
      "sandbox": {
        "mode": "off"
      },
      "thinkingDefault": "low",
      "timeoutSeconds": 600,
      "workspace": "/home/node/.openclaw/workspace",
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "model": "openai/text-embedding-3-small",
        "remote": {
          "baseUrl": "https://openrouter.ai/api/v1",
          "apiKey": "${OPENROUTER_API_KEY}"
        },
        "sources": [
          "memory"
        ],
        "query": {
          "maxResults": 6,
          "minScore": 0.3,
          "hybrid": {
            "mmr": {
              "enabled": true
            },
            "temporalDecay": {
              "enabled": true
            }
          }
        },
        "sync": {
          "onSessionStart": true,
          "onSearch": true,
          "watch": true
        }
      }
    }
  },
  "auth": {
    "profiles": {
      "openrouter:default": {
        "mode": "api_key",
        "provider": "openrouter"
      }
    }
  },
  "channels": {
    "telegram": {
      "allowFrom": [
        "7540422842"
      ],
      "dmPolicy": "allowlist",
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "tokenFile": "<set manually>"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "<set manually>"
    },
    "bind": "loopback",
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18791"
      ]
    },
    "mode": "local",
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    },
    "port": 18791,
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "hooks": {
    "internal": {
      "entries": {
        "session-memory": {
          "enabled": false
        },
        "command-logger": {
          "enabled": true
        }
      },
      "enabled": true
    }
  },
  "plugins": {
    "allow": [
      "memory-lancedb"
    ],
    "slots": {
      "memory": "memory-lancedb"
    },
    "entries": {
      "anthropic": {
        "enabled": true
      },
      "openrouter": {
        "enabled": true
      },
      "active-memory": {
        "enabled": true,
        "config": {
          "enabled": true,
          "agents": [
            "main"
          ],
          "allowedChatTypes": [
            "direct"
          ],
          "queryMode": "recent",
          "promptStyle": "balanced",
          "timeoutMs": 15000,
          "maxSummaryChars": 220,
          "persistTranscripts": false,
          "logging": true
        }
      },
      "memory-lancedb": {
        "enabled": true,
        "config": {
          "dbPath": "~/.openclaw/memory/lancedb",
          "embedding": {
            "apiKey": "${OPENROUTER_API_KEY}",
            "baseUrl": "https://openrouter.ai/api/v1",
            "model": "openai/text-embedding-3-small",
            "dimensions": 1536
          },
          "autoRecall": true,
          "autoCapture": false,
          "captureMaxChars": 500
        }
      }
    },
    "installs": {},
    "load": {
      "paths": []
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "skills": {
    "entries": {
      "coding-harness": {
        "enabled": true
      },
      "cursor-agent-login": {
        "enabled": true
      },
      "gog": {
        "enabled": true
      },
      "gog-reauth": {
        "enabled": true
      },
      "memory-cold-store": {
        "enabled": true
      },
      "mira-memory": {
        "enabled": true
      },
      "n8n": {
        "enabled": true
      },
      "model-usage": {
        "enabled": false
      },
      "session-logs": {
        "enabled": false
      }
    }
  },
  "tools": {
    "allow": [
      "read",
      "exec",
      "process",
      "memory_recall",
      "memory_store",
      "memory_forget"
    ],
    "exec": {
      "host": "gateway"
    },
    "profile": "coding",
    "sessions": {
      "visibility": "agent"
    }
  }
}
