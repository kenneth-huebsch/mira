# Accumulated private memory is intentionally not synced.
# Required restore seed files under workspace/memory are force-added below.
workspace/memory/*.jsonl
workspace/memory/.dreams/
!workspace/memory/medium_memory.jsonl
!workspace/memory/long_memory.jsonl
!workspace/memory/engagement_memory.jsonl
!workspace/memory/engagement_priorities.jsonl
